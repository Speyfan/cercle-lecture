generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  passwordHash      String
  role              String   @default("user")
  newsletterEnabled Boolean  @default(true)
  active            Boolean  @default(true)
  emailVerified     DateTime?
  createdAt         DateTime @default(now())

  reviews            Review[]
  recommendations    Recommendation[]
  batches            RecommendationBatch[]
  verificationTokens EmailVerificationToken[]
}

model EmailVerificationToken {
  token     String   @id
  userId    String
  email     String // adresse au moment de l'envoi (détecte un changement entre-temps)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Book {
  id             String  @id @default(cuid())
  title          String
  author         String
  openLibraryKey String? @unique
  coverUrl       String?

  createdAt DateTime @default(now())
  reviews   Review[]

  @@unique([title, author])
}

model Review {
  id      String  @id @default(cuid())
  userId  String
  bookId  String
  rating  Int
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model RecommendationBatch {
  id          String   @id @default(cuid())
  userId      String
  month       String
  generatedAt DateTime @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]

  @@unique([userId, month])
}

model Recommendation {
  id             String  @id @default(cuid())
  userId         String
  batchId        String
  title          String
  author         String
  reason         String
  coverUrl       String?
  openLibraryKey String?
  verified       Boolean @default(false)
  status         String  @default("EN_ATTENTE")

  createdAt DateTime @default(now())

  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch RecommendationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}
