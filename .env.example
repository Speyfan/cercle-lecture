# --- Application ---
APP_URL=https://cercle-lecture.duckdns.org   # sous-domaine DuckDNS, en HTTPS
APP_DOMAIN=cercle-lecture.duckdns.org        # utilisé par Caddy pour le certificat HTTPS
NODE_ENV=production

# --- Base de données (SQLite) ---
DATABASE_URL=file:/data/app.db               # fichier sur le volume monté Docker

# --- Authentification (Auth.js) ---
AUTH_SECRET=                                  # openssl rand -base64 32
REGISTRATION_CODE=                            # code d'invitation partagé au cercle
ADMIN_EMAIL=                                  # email du compte qui devient admin automatiquement

# --- IA (Anthropic Claude) — Phase 2 ---
AI_API_KEY=                                   # clé API Anthropic (sk-ant-...)
AI_MODEL=claude-sonnet-4-5                    # modèle utilisé pour les recommandations

# --- Email (Brevo SMTP) — Phase 2 ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=                                    # identifiant SMTP Brevo (votre email Brevo)
SMTP_PASS=                                    # clé SMTP Brevo
MAIL_FROM=                                    # adresse expéditrice vérifiée dans Brevo

# --- Cron interne — Phase 2 ---
CRON_SECRET=                                  # openssl rand -hex 32
TZ=Europe/Paris                               # fuseau pour le déclenchement mensuel (1er du mois 08h00)
